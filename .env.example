# ==========================================================
# ShroomHarvest — Environment Variables
# Copy this file to `.env` in app/server and fill in real values.
# Never commit the real .env file.
# ==========================================================

# ---- Shopify App Credentials ----
# Get these from your Partner Dashboard > Apps > (your app) > Client credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Comma-separated list, no spaces. Start minimal, expand as modules need more.
SHOPIFY_SCOPES=read_products,write_products,read_inventory,write_inventory,read_orders
# Must match the tunnel URL Shopify CLI gives you, e.g. https://your-app.trycloudflare.com
SHOPIFY_APP_URL=https://localhost:3000
# Set automatically by `shopify app dev`, only needed if running server standalone
SCOPES=read_products,write_products,read_inventory,write_inventory,read_orders

# ---- Database (MySQL via Docker) ----
DATABASE_URL=mysql://shroomharvest_user:shroomharvest_pass@localhost:3306/shroomharvest
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=shroomharvest
MYSQL_USER=shroomharvest_user
MYSQL_PASSWORD=shroomharvest_pass
MYSQL_PORT=3306

# ---- Server ----
PORT=3000
NODE_ENV=development
SESSION_SECRET=replace_with_a_long_random_string

# ---- Client (Vite exposes only VITE_ prefixed vars) ----
VITE_SHOPIFY_API_KEY=
