<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>
      {{ page_title }}{% if page_title != shop.name %} &middot; {{ shop.name }}{% endif %}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    <link rel="canonical" href="{{ canonical_url }}">
    <meta name="theme-color" content="{{ settings.color_primary }}">
    {{ content_for_header }}

    {{ 'base.css' | asset_url | stylesheet_tag }}

    {% comment %}
      Theme settings (Colors panel in the theme editor) override the static
      defaults in base.css via CSS custom properties, so merchants can
      retint the storefront without touching code.
    {% endcomment %}
    {% style %}
      :root {
        --color-bg: {{ settings.color_bg }};
        --color-text: {{ settings.color_text }};
        --color-primary: {{ settings.color_primary }};
        --color-accent: {{ settings.color_accent }};
        --color-sage: {{ settings.color_sage }};
        --page-max-width: {{ settings.page_width }}px;
        {% if settings.heading_font_style == 'sans' %}
          --font-heading: var(--font-body);
        {% endif %}
      }
    {% endstyle %}
  </head>
  <body>
    <a class="visually-hidden skip-to-content-link" href="#MainContent">
      Skip to content
    </a>

    {% section 'header' %}

    <main id="MainContent">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    {{ 'global.js' | asset_url | script_tag }}
  </body>
</html>
