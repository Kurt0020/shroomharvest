<div class="page-width section-padding">
  <div class="section-heading">
    {% if section.settings.eyebrow != blank %}
      <div class="section-heading__eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
  </div>

  {% if section.blocks.size > 0 %}
    <div class="reviews-carousel-wrap">
      <button type="button" class="reviews-nav reviews-nav--prev" data-reviews-prev aria-label="Previous review">&larr;</button>

      <div class="reviews-carousel" data-reviews-track tabindex="0" aria-label="Customer reviews">
        {% for block in section.blocks %}
          <div class="review-card" {{ block.shopify_attributes }}>
            <div class="review-card__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {% for i in (1..5) %}
                {% if i <= block.settings.rating %}★{% else %}☆{% endif %}
              {% endfor %}
            </div>
            <p class="review-card__quote">&ldquo;{{ block.settings.quote }}&rdquo;</p>
            <p class="review-card__author">
              {{ block.settings.author }}
              {% if block.settings.location != blank %}
                <span class="review-card__location">&middot; {{ block.settings.location }}</span>
              {% endif %}
            </p>
          </div>
        {% endfor %}
      </div>

      <button type="button" class="reviews-nav reviews-nav--next" data-reviews-next aria-label="Next review">&rarr;</button>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Customer reviews",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "From our customers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by home cooks and daily sippers alike" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "The grow kit fruited in 9 days and my kids won't stop checking on it. Genuinely delicious oyster mushrooms too."
        },
        { "type": "text", "id": "author", "label": "Author name", "default": "Jamie R." },
        { "type": "text", "id": "location", "label": "Location (optional)", "default": "Portland, OR" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer reviews",
      "blocks": [
        { "type": "review", "settings": { "author": "Jamie R.", "location": "Portland, OR" } },
        { "type": "review", "settings": { "author": "Priya K.", "location": "Austin, TX" } },
        { "type": "review", "settings": { "author": "Sam T.", "location": "Burlington, VT" } }
      ]
    }
  ]
}
{% endschema %}
