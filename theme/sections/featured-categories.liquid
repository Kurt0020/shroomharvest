<div class="page-width section-padding">
  <div class="section-heading">
    {% if section.settings.eyebrow != blank %}
      <div class="section-heading__eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p style="color: var(--color-text-muted);">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="category-grid">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.collection.url | default: '#' }}"
          class="category-card"
          {{ block.shopify_attributes }}
        >
          <div class="category-card__media">
            {% if block.settings.image %}
              <img
                src="{{ block.settings.image | image_url: width: 500 }}"
                alt="{{ block.settings.title | escape }}"
                width="500"
                height="500"
                loading="lazy"
              >
            {% elsif block.settings.collection.featured_image %}
              <img
                src="{{ block.settings.collection.featured_image | image_url: width: 500 }}"
                alt="{{ block.settings.title | escape }}"
                width="500"
                height="500"
                loading="lazy"
              >
            {% endif %}
          </div>
          <div class="category-card__label">{{ block.settings.title }}</div>
        </a>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Featured categories",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Shop by category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your kind of mushroom" },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From weeknight dinners to daily wellness routines."
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Fresh Mushrooms" },
        { "type": "collection", "id": "collection", "label": "Collection" },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (optional — uses collection image if left blank)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured categories",
      "blocks": [
        { "type": "category", "settings": { "title": "Fresh Mushrooms" } },
        { "type": "category", "settings": { "title": "Dried Mushrooms" } },
        { "type": "category", "settings": { "title": "Mushroom Coffee" } },
        { "type": "category", "settings": { "title": "Mushroom Tea" } },
        { "type": "category", "settings": { "title": "Powders & Supplements" } },
        { "type": "category", "settings": { "title": "Grow Kits" } }
      ]
    }
  ]
}
{% endschema %}
