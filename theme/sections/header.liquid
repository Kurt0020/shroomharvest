<header class="site-header">
  <div class="page-width site-header__inner">
    <a href="{{ routes.root_url }}" class="site-header__logo">
      {% if section.settings.logo %}
        <img
          src="{{ section.settings.logo | image_url: width: 320 }}"
          alt="{{ shop.name }}"
          width="160"
          height="{{ 160 | divided_by: section.settings.logo.aspect_ratio }}"
          loading="eager"
        >
      {% else %}
        {{ section.settings.logo_text | default: shop.name }}
      {% endif %}
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {% for link in section.settings.menu.links %}
          <li>
            <a href="{{ link.url }}" class="site-nav__link"{% if link.active %} aria-current="page"{% endif %}>
              {{ link.title }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <div class="site-header__actions">
      <a href="{{ routes.cart_url }}" class="icon-btn" aria-label="Cart, {{ cart.item_count }} item{{ cart.item_count | pluralize: '', 's' }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        {% if cart.item_count > 0 %}
          <span class="cart-count" data-cart-count>{{ cart.item_count }}</span>
        {% endif %}
      </a>

      <button type="button" class="mobile-nav-toggle" aria-expanded="false" aria-controls="MobileNav" data-mobile-nav-toggle>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <span class="visually-hidden">Menu</span>
      </button>
    </div>
  </div>

  <nav class="mobile-nav page-width" id="MobileNav" aria-label="Mobile" data-mobile-nav>
    {% for link in section.settings.menu.links %}
      <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
    {% endfor %}
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image (optional)"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (used if no image is set)",
      "default": "ShroomHarvest"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
