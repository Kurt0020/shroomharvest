<div class="page-width section-padding">
  <div class="section-heading">
    {% if section.settings.eyebrow != blank %}
      <div class="section-heading__eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
  </div>

  {% if section.blocks.size > 0 %}
    <div class="faq-list">
      {% for block in section.blocks %}
        <details class="faq-item" {{ block.shopify_attributes }}>
          <summary class="faq-item__question">
            {{ block.settings.question }}
            <span class="faq-item__icon" aria-hidden="true">+</span>
          </summary>
          <div class="faq-item__answer">{{ block.settings.answer }}</div>
        </details>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Good to know" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How should I store fresh mushrooms?" },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Keep them in a paper bag (not plastic) in the fridge — they'll stay fresh for 5-7 days.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "question", "settings": { "question": "How should I store fresh mushrooms?" } },
        {
          "type": "question",
          "settings": {
            "question": "How long do grow kits take to fruit?",
            "answer": "<p>Most kits fruit within 7-14 days of unboxing, given indirect light and a light daily misting.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Are your supplements third-party tested?",
            "answer": "<p>Yes — every batch is tested for potency and purity before it ships, and certificates are available on request.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Do you ship internationally?",
            "answer": "<p>Currently we ship within the US and Canada. International shipping is on our roadmap.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
