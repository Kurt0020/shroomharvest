<div class="page-width section-padding" style="background: var(--color-bg-alt); border-radius: var(--radius-lg);">
  <div class="section-heading">
    {% if section.settings.eyebrow != blank %}
      <div class="section-heading__eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p style="color: var(--color-text-muted);">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="benefits-grid">
      {% for block in section.blocks %}
        <div class="benefit-card" {{ block.shopify_attributes }}>
          <div class="benefit-card__icon" aria-hidden="true">
            {% case block.settings.icon %}
              {% when 'immune' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2l7 3v6c0 5-3.5 8.5-7 9-3.5-.5-7-4-7-9V5l7-3z"></path></svg>
              {% when 'focus' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"></circle><circle cx="12" cy="12" r="4"></circle></svg>
              {% when 'energy' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><polygon points="13 2 3 14 11 14 9 22 21 10 13 10 13 2"></polygon></svg>
              {% when 'grow' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 22V12"></path><path d="M12 12C12 6 7 5 4 5c0 4 1.5 8 8 7z"></path><path d="M12 12c0-6 5-7 8-7 0 4-1.5 8-8 7z"></path></svg>
              {% when 'culinary' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 2v6a2 2 0 0 0 2 2h0a2 2 0 0 0 2-2V2"></path><path d="M6 2v20"></path><path d="M18 2c-2 0-3 1.5-3 4s1 5 3 5 3-2 3-5-1-4-3-4z"></path><path d="M18 11v11"></path></svg>
              {% else %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2a5 5 0 0 1 5 5c0 2-1 3-1 5h-8c0-2-1-3-1-5a5 5 0 0 1 5-5z"></path><path d="M9 17h6"></path><path d="M10 21h4"></path></svg>
            {% endcase %}
          </div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Mushroom benefits",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Why mushrooms" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Function meets flavor" },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every product is chosen for a reason — here's what to look for based on your goal."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "immune", "label": "Immune support (shield)" },
            { "value": "focus", "label": "Focus (target)" },
            { "value": "energy", "label": "Energy (bolt)" },
            { "value": "grow", "label": "Home growing (sprout)" },
            { "value": "culinary", "label": "Culinary (utensils)" },
            { "value": "wellness", "label": "General wellness" }
          ],
          "default": "wellness"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Immune support" },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Reishi and Turkey Tail are prized for their beta-glucan content, a favorite among daily wellness routines."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mushroom benefits",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "immune", "title": "Immune support", "text": "Reishi and Turkey Tail are prized for their beta-glucan content." } },
        { "type": "benefit", "settings": { "icon": "focus", "title": "Focus & clarity", "text": "Lion's Mane is a favorite for sustained, jitter-free focus." } },
        { "type": "benefit", "settings": { "icon": "energy", "title": "Natural energy", "text": "Cordyceps blends offer a gentler lift than a third cup of coffee." } },
        { "type": "benefit", "settings": { "icon": "grow", "title": "Grow your own", "text": "Our beginner-friendly kits fruit in as little as 10 days." } }
      ]
    }
  ]
}
{% endschema %}
